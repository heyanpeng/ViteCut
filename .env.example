# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=vitecut
# API
PORT=3001
# 阿里云 OSS（必填）
OSS_REGION=cn-hangzhou
OSS_BUCKET=vitecut
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
# 可选
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_PUBLIC_BASE_URL=https://your-cdn-domain.com
OSS_KEY_PREFIX=vitecut
OSS_STS_TOKEN=
OSS_INTERNAL=false
OSS_SECURE=true
OSS_READ_URL_EXPIRES_SECONDS=900
# JWT 鉴权（生产环境务必设置）
JWT_SECRET=jwt_secret
# 火山方舟（豆包 Seedream 图片生成）https://www.volcengine.com/docs/82379/1541523
# 需在控制台创建推理接入点，获取 API Key 和各模型的 Endpoint ID
ARK_API_KEY=your_ark_api_key
ARK_ENDPOINT_DOUBAO_SEEDREAM_5_0_LITE=ep-xxx
ARK_ENDPOINT_DOUBAO_SEEDREAM_4_5=ep-xxx
ARK_ENDPOINT_DOUBAO_SEEDREAM_4_0=ep-xxx
ARK_ENDPOINT_DOUBAO_SEEDREAM_3_0_T2I=ep-xxx
ARK_ENDPOINT_SEED_1_8=ep-xxx
ARK_ENDPOINT_SEEDANCE_1_5_PRO=ep-xxx
ARK_ENDPOINT_SEEDANCE_1_0_PRO=ep-xxx
# Pexels API 密钥
VITE_PEXELS_API_KEY=your_pexels_api_key
# FreeSound API 密钥
VITE_FREESOUND_API_KEY=your_freesound_api_key
